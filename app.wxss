page {
  background: #f6f7fb;
  color: #182033;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
}

.page {
  padding: 28rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 35, 60, 0.06);
}

.muted {
  color: #6f7482;
}

.tag {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #1677ff;
  background: #eaf3ff;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.primary-btn {
  background: #1677ff;
  color: #ffffff;
  border-radius: 14rpx;
  font-weight: 600;
}

.secondary-btn {
  background: #eef4ff;
  color: #1677ff;
  border-radius: 14rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.field {
  background: #f7f8fb;
  border-radius: 12rpx;
  padding: 22rpx;
  margin-top: 18rpx;
}

.field-label {
  display: block;
  color: #6f7482;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

input,
textarea {
  width: 100%;
  font-size: 30rpx;
}

textarea {
  min-height: 140rpx;
}
